.config/kitty/kitty.conf.bak
.config/nvim/lazy-lock.json
.config/gh/hosts.yml
Library/Application Support/lazygit/state.yml

# VS Code — only track settings.json and keybindings.json
Library/Application Support/Code/*
!Library/Application Support/Code/User/
Library/Application Support/Code/User/*
!Library/Application Support/Code/User/settings.json
!Library/Application Support/Code/User/keybindings.json

# Claude Code — only track CLAUDE.md, settings.json, statusline-command.sh
.claude/*
!.claude/CLAUDE.md
!.claude/settings.json
!.claude/statusline-command.sh

# Alfred — ignore passwords, machine-local prefs, Remote app icons, and legacy files
manual/alfred/Alfred.alfredpreferences/snippets/passwords/
manual/alfred/Alfred.alfredpreferences/remote/
manual/alfred/Alfred.alfredpreferences/preferences/local/
manual/alfred/themes/
manual/alfred/terminal_custom.applescript
